@page "/animals"

<MudText Typo="Typo.h4" GutterBottom="true">
    Animals
</MudText>

<MudText Typo="Typo.body1" Class="mb-4">
    Pregled životinja koje se nalaze u sustavu azila.
</MudText>

<MudPaper Class="pa-4" Elevation="2">
    <MudText Typo="Typo.h5">Životinje u azilu</MudText>
    <MudText Typo="Typo.body2">
        Ovdje će se kasnije prikazivati osnovni podaci o životinjama.
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="4" Class="d-flex">
            <MudPaper Class="pa-4 d-flex flex-column" Outlined="true" Style="width:100%">
                <MudImage Src="images/doggo.jpeg"
                          Alt="Slika psa"
                          Fluid="true"
                          Class="mb-3"/>
                <MudText Typo="Typo.h6">Sve životinje</MudText>
                <MudText Typo="Typo.body2">
                    Pregled svih životinja evidentiranih u azilu.
                </MudText>
                <MudButton Variants="Variant.Filled"
                           Color="Color.Primary"
                           Class="mt-3">
                        Otvori pregled
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="d-flex">
            <MudPaper Class="pa-4 d-flex flex-column" Outlined="true" Style="width:100%">
                <MudImage Src="images/pasmine.jpg"
                          Alt="Slika različitih pasmina"
                          Fluid="true"
                          Class="mb-3" />
                <MudText Typo="Typo.h6">Vrste i pasmine</MudText>
                <MudText Typo="Typo.body2">
                    Organizacija životinja prema vrstama i pasminama.
                </MudText>
                <MudButton Variants="Variant.Filled"
                           Color="Color.Primary"
                           Class="mt-3">
                    Pogledaj vrste
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="d-flex">
            <MudPaper Class="pa-4 d-flex flex-column" Outlined="true" Style="width:100%">
                <MudImage Src="images/kavezi.jpg"
                          Alt="Izgled Splitskog azila"
                          Fluid="true"
                          Class="mb-3" />
                <MudText Typo="Typo.h6">Smještaj</MudText>
                <MudText Typo="Typo.body2">
                    Pregled bokseva, kaveza i drugih smještajnih jedinica.
                </MudText>
                <MudButton Variants="Variant.Filled"
                           Color="Color.Primary"
                           Class="mt-3">
                    Pogledaj smještaj
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4" Class="d-flex">
            <MudPaper Class="pa-4 d-flex flex-column" Outlined="true" Style="width:100%">
                <MudImage Src="images/units.jpg"
                          Alt="Izgled bokseva"
                          Fluid="true"
                          Class="mb-3"/>
                <MudText Typo="Typo.h6">
                    Housing units
                </MudText>
                <MudText Typo="Typo.body2">
                    Pregled bokseva, kaveza i drugih smještajnih jedinica
                </MudText>
                <MudButton Variants="Variant.Filled"
                           Color="Color.Primary"
                           Class="mt-3">
                    Pogledaj kaveze
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

