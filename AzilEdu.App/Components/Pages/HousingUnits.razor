@page "/housing-units"
@rendermode InteractiveServer
@using AzilEdu.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Smještajne jedinice</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Smještajne jedinice</MudText>
<MudText Typo="Typo.body1" Class="mb-4">
    Ovdje se prikazuje pregled boksova, soba i drugih prostora u kojima se životinje
    trenutačno nalaze u azilu, zajedno s popunjenošću i statusom svake jedinice.
</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Ukupno jedinica</MudText>
            <MudText Typo="Typo.h5">@TotalUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Aktivnih jedinica</MudText>
            <MudText Typo="Typo.h5">@ActiveUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Punih jedinica</MudText>
            <MudText Typo="Typo.h5">@FullUnits</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Slobodan kapacitet</MudText>
            <MudText Typo="Typo.h5">@TotalFreeCapacity</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Class="mb-4">
    <MudButton OnClick="@ShowAllUnits">Sve</MudButton>
    <MudButton OnClick="@ShowActiveUnits">Aktivne</MudButton>
    <MudButton OnClick="@ShowFullUnits">Pune</MudButton>
    <MudButton OnClick="@ShowFreeUnits">Slobodno</MudButton>
</MudButtonGroup>

<MudTable Items="@FilteredHousingUnits" Hover="true" Striped="true" Bordered="true" Dense="true">
    <HeaderContent>
        <MudTh>Slika</MudTh>
        <MudTh>Naziv</MudTh>
        <MudTh>Tip</MudTh>
        <MudTh>Kapacitet</MudTh>
        <MudTh>Zauzeto</MudTh>
        <MudTh>Slobodno</MudTh>
        <MudTh>Zadnje čišćenje</MudTh>
        <MudTh>Status</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Slika">
            <MudAvatar Size="Size.Large">
                <MudImage Src="@context.ImageUrl" Alt="@context.Name" />
            </MudAvatar>
        </MudTd>
        <MudTd DataLabel="Naziv">@context.Name</MudTd>
        <MudTd DataLabel="Tip">@context.UnitType</MudTd>
        <MudTd DataLabel="Kapacitet">@context.Capacity</MudTd>
        <MudTd DataLabel="Zauzeto">@context.Occupied</MudTd>
        <MudTd DataLabel="Slobodno">@GetFreeCapacity(context)</MudTd>
        <MudTd DataLabel="Zadnje čišćenje">@GetCleaningDateText(context)</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="@GetUnitStatusColor(context)"
                     Variant="Variant.Filled">
                @GetUnitStatusText(context)
            </MudChip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    protected override async Task OnInitializedAsync()
    {
        List<HousingUnit>? result = await Http.GetFromJsonAsync<List<HousingUnit>>("api/housingunits");
        housingUnits = result ?? new List<HousingUnit>();
    }

    private string selectedHousingFilter = "Sve";

    private List<HousingUnit> housingUnits = new();

    private int TotalUnits => housingUnits.Count;

    private int ActiveUnits => housingUnits.Count(unit => unit.IsActive);

    private int FullUnits => housingUnits.Count(unit => unit.IsActive && GetFreeCapacity(unit) == 0);

    private int TotalFreeCapacity => housingUnits.Where(unit => unit.IsActive).Sum(unit => GetFreeCapacity(unit));

    private IEnumerable<HousingUnit> FilteredHousingUnits =>
        selectedHousingFilter switch
        {
            "Aktivne" => housingUnits.Where(unit => unit.IsActive),
            "Pune" => housingUnits.Where(unit => unit.IsActive && GetFreeCapacity(unit) == 0),
            "Slobodno" => housingUnits.Where(unit => unit.IsActive && GetFreeCapacity(unit) > 0),
            _ => housingUnits
        };

    private void ShowAllUnits()
    {
        selectedHousingFilter = "Sve";
    }

    private void ShowActiveUnits()
    {
        selectedHousingFilter = "Aktivne";
    }

    private void ShowFullUnits()
    {
        selectedHousingFilter = "Pune";
    }

    private void ShowFreeUnits()
    {
        selectedHousingFilter = "Slobodno";
    }

    private int GetFreeCapacity(HousingUnit unit)
    {
        return unit.Capacity - unit.Occupied;
    }

    private string GetCleaningDateText(HousingUnit unit)
    {
        if (unit.LastCleanedAt.HasValue)
        {
            return unit.LastCleanedAt.Value.ToShortDateString();
        }

        return "Nije uneseno";
    }

    private string GetUnitStatusText(HousingUnit unit)
    {
        if (!unit.IsActive)
        {
            return "Neaktivno";
        }

        if (unit.Occupied >= unit.Capacity)
        {
            return "Puno";
        }

        return "Slobodno";
    }

    private Color GetUnitStatusColor(HousingUnit unit)
    {
        if (!unit.IsActive)
        {
            return Color.Default;
        }

        if (unit.Occupied >= unit.Capacity)
        {
            return Color.Error;
        }

        return Color.Success;
    }
}
