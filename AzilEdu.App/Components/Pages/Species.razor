@page "/species"

<MudText Typo="Typo.h4" GutterBottom="true">Species</MudText>

<MudText Typo="Typo.body2">
    Na ovoj stranici možete pregledati koje sve vrste životinja imamo u azilu
</MudText>

<MudPaper Class="pa-4" Elevation="2">
     <MudGrid>
         @foreach (var card in _cards)
        {
            <MudItem xs="12" md="4" Class="d-flex">
                <MudPaper Class="pa-4 d-flex flex-column" Outlined="true" Style="width:100%">
                    <MudImage Src="@card.Img"
                              Alt="@card.Name"
                              Fluid="true"
                              Class="mb-3" 
                              Style="width:100px; height:100px; border-radius:6px;"/>
                    <MudText Typo="Typo.h6" Class="mt-3">@card.Name</MudText>
                    <MudText Typo="Typo.caption" Style="font-style:italic; color:gray">
                        @card.LatinName
                    </MudText>

                    <MudText Typo="Typo.body2" Class="flex-grow-1 mb-2">
                        @card.Description
                    </MudText>

                    <MudText Typo="Typo.body2">
                        <b>Životni vijek:</b> 
                        @card.LifeSpan
                    </MudText>
                    <MudText Typo="Typo.body2">
                        <b>Prehrana:</b>
                        @card.Diet
                    </MudText>
                    <MudText Typo="Typo.body2">
                        <b>Broj jedinki:</b>
                        @card.Population
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mb-1">
                        <b>Vrste u azilu:</b>
                    </MudText>
                    <MudGrid xs="12" md="4" Class="d-flex">
                        @foreach (var animal in card.InHolding)
                        {
                            <MudItem xs="12" md="4" Class="d-flex">
                                <MudPaper Class="pa-4 d-flex flex-column" Outlined="true" Style="width:100%">
                                    <MudText>
                                        @animal
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-3">
                        @card.ButtonText
                    </MudButton>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudPaper>


